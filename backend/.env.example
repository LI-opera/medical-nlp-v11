# 复制为 backend/.env 后填写本地配置；不要把真实密钥提交到 Git。

# DeepSeek：主链路扩写、验证、反思和错误解释使用。
DEEPSEEK_API_KEY=replace_with_your_deepseek_key

# 可选：如果启用 Qwen/通义千问相关能力时填写。
DASHSCOPE_API_KEY=replace_with_your_dashscope_key

# 本机运行时使用 127.0.0.1；Docker Compose 中由 compose 覆盖为 http://milvus:19530。
MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION_NAME=concepts_only_name
MILVUS_RXNORM_COLLECTION=rxnorm_concepts

# Benchmark 并行 worker 数。网页上传通常由接口显式传入；手动运行时可改为 2。
BENCH_WORKERS=1

# 反思重试和日志滚动参数，可按本机资源调整。
REFLECT_MAX_ITER=2
LOG_MAX_FILE_MB=10
LOG_MAX_BACKUPS=5
LOG_RAW_OUTPUT_MAX_CHARS=2000
